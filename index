            <div class="ph-row-val">50%</div>
          </div>
          <div class="ph-row">
            <div class="ph-row-label">pH 8.0</div>
            <div class="ph-bar-bg"><div class="ph-bar-fill c-low" style="width:24%"></div></div>
            <div class="ph-row-val">24%</div>
          </div>
          <div class="ph-row">
            <div class="ph-row-label">pH 8.5</div>
            <div class="ph-bar-bg"><div class="ph-bar-fill c-low" style="width:9.1%"></div></div>
