<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>畜舎全体の衛生環境を変える｜水中除菌タブレット クリアンス（CREINS）</title>
  <meta name="description" content="クリアンス（CREINS）は飲水ライン・畜舎内・空間の3つのアプローチで畜舎全体の衛生管理をサポート。pH非依存・耐性形成なし・皮膚刺激性低い。全国100件以上の農場・施設での導入実績（CLOX社調べ）。">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }

    :root {
      --primary:      #5bc3ec;
      --primary-sub:  #2ca6e0;
      --primary-deep: #084d9f;
      --primary-mid:  #2b5ea8;
      --primary-bg:   rgba(91, 195, 236, 0.10);
      --text:         #333333;
      --text-mid:     #556270;
      --text-light:   #7f8a94;
      --white:        #ffffff;
      --surface:      #fafafa;
      --surface-alt:  #f7f7f7;
      --surface-blue: #d4dfed;
      --border:       #d9e7f1;
      --border-mid:   #c2d6e5;
      --green:        #1d7a4a;
      --green-bg:     #eaf4ee;
      --indicator-bad:#b03030;
      --container:    1200px;
      --section:      90px 0;
    }

    html { scroll-behavior: smooth; font-size: 16px }

    body {
      font-family: 'Noto Sans JP', sans-serif;
      color: var(--text);
      line-height: 1.8;
      overflow-x: hidden;
      background: var(--white);
    }

    img { max-width: 100%; height: auto; display: block }
    a { text-decoration: none; color: inherit }
    strong { font-weight: 700 }

    .container { max-width: var(--container); margin: 0 auto; padding: 0 24px }
    section { padding: var(--section) }

    h2.section-title {
      font-size: 2.15rem;
      font-weight: 700;
      color: var(--primary-deep);
      letter-spacing: .04em;
      line-height: 1.45;
      margin-bottom: 12px;
    }

    .section-label {
      font-family: 'Montserrat', sans-serif;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--primary-deep);
      margin-bottom: 12px;
    }

    .section-sub {
      color: var(--text-light);
      font-size: .9rem;
      margin-bottom: 56px;
      line-height: 1.7;
    }

    .divider {
      width: 40px;
      height: 2px;
      background: var(--primary);
      margin: 16px 0 40px;
    }
    .divider.center { margin: 16px auto 40px }

    /* ── Buttons ── */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--primary);
      color: var(--white);
      font-family: 'Montserrat', 'Noto Sans JP', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      padding: 16px 62px 16px 36px;
      border-radius: 999px;
      border: 1px solid var(--primary);
      cursor: pointer;
      transition: all .25s;
      letter-spacing: .05em;
      position: relative;
      box-shadow: 0 12px 32px rgba(91, 195, 236, .25);
    }
    .btn-primary:hover {
      background: transparent;
      border-color: var(--primary);
      color: var(--primary);
      box-shadow: none;
    }

    .btn-outline {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      color: var(--primary);
      font-family: 'Montserrat', 'Noto Sans JP', sans-serif;
      font-weight: 700;
      font-size: .9rem;
      padding: 14px 58px 14px 32px;
      border-radius: 999px;
      border: 1.5px solid var(--primary);
      cursor: pointer;
      transition: all .25s;
      letter-spacing: .05em;
      position: relative;
    }
    .btn-outline:hover {
      background: var(--primary);
      color: var(--white);
    }

    .btn-outline-white {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      color: var(--white);
      font-family: 'Montserrat', 'Noto Sans JP', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      padding: 16px 62px 16px 36px;
      border-radius: 999px;
      border: 1.5px solid rgba(255,255,255,.6);
      cursor: pointer;
      transition: all .25s;
      letter-spacing: .05em;
      position: relative;
    }
    .btn-outline-white:hover {
      background: var(--white);
      border-color: var(--white);
      color: var(--primary-deep);
    }

    .btn-primary::after,
    .btn-outline::after,
    .btn-outline-white::after {
      content: '';
      position: absolute;
      right: 24px;
      top: 50%;
      width: 10px;
      height: 10px;
      transform: translateY(-50%) rotate(45deg);
      border-top: 1.5px solid currentColor;
      border-right: 1.5px solid currentColor;
    }

    .btn-primary-light {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--white);
      color: var(--primary-deep);
      font-family: 'Montserrat', 'Noto Sans JP', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      padding: 16px 62px 16px 36px;
      border-radius: 999px;
      border: 1px solid var(--white);
      cursor: pointer;
      transition: all .25s;
      letter-spacing: .05em;
      position: relative;
      box-shadow: 0 16px 36px rgba(0, 0, 0, .14);
    }

    .btn-primary-light:hover {
      background: transparent;
      color: var(--white);
      box-shadow: none;
    }

    .btn-primary-light::after {
      content: '';
      position: absolute;
      right: 24px;
      top: 50%;
      width: 10px;
      height: 10px;
      transform: translateY(-50%) rotate(45deg);
      border-top: 1.5px solid currentColor;
      border-right: 1.5px solid currentColor;
    }

    .floating-cta {
      position: fixed;
      right: 24px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 95;
      width: 188px;
      padding: 16px 16px 18px;
      border-radius: 24px;
      background: rgba(255,255,255,.94);
      border: 1px solid rgba(91, 195, 236, .35);
      box-shadow: 0 20px 42px rgba(8, 77, 159, .14);
      backdrop-filter: blur(10px);
      transition: opacity .25s ease, transform .25s ease, visibility .25s ease;
    }

    .floating-cta.is-hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(-50%) translateX(12px);
    }

    .floating-cta-label {
      display: block;
      margin-bottom: 8px;
      font-family: 'Montserrat', sans-serif;
      font-size: .64rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--primary-sub);
    }

    .floating-cta-copy {
      font-size: .78rem;
      line-height: 1.65;
      color: var(--text-mid);
      margin-bottom: 14px;
    }

    .floating-cta .btn-primary {
      width: 100%;
      min-height: 54px;
      padding: 14px 52px 14px 24px;
      font-size: .88rem;
      white-space: nowrap;
      box-shadow: 0 10px 24px rgba(91, 195, 236, .22);
    }

    /* ── Header ── */
    .header {
      background: linear-gradient(to bottom, rgba(255,255,255,.96), rgba(255,255,255,.88));
      border-bottom: 1px solid rgba(217, 231, 241, .85);
      padding: 14px 0;
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(10px);
      box-shadow: 0 8px 28px rgba(8, 77, 159, .06);
    }
    .header .container { display: flex; align-items: center; justify-content: space-between }
    .header-logo { display: flex; flex-direction: column; line-height: 1.2 }
    .header-logo-main {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--primary-deep);
      letter-spacing: .04em;
    }
    .header-logo-sub { font-size: .72rem; color: var(--text-light); letter-spacing: .02em }
    .header-right { display: flex; align-items: center; gap: 24px }
    .header-tel { font-size: .85rem; color: var(--primary-deep); font-weight: 500; font-family: 'Montserrat', sans-serif }
    .header-tel-label { font-family: 'Noto Sans JP', sans-serif; font-size: .7rem; color: var(--text-light); display: block; margin-bottom: 1px }

    /* ── Hero ── */
    .hero {
      background:
        radial-gradient(circle at top right, rgba(91,195,236,.20), transparent 32%),
        linear-gradient(120deg, rgba(255,255,255,1) 0%, rgba(250,250,250,1) 48%, rgba(212,223,237,.55) 100%);
      min-height: calc(100vh - 82px);
      display: flex;
      align-items: center;
      padding: 56px 0 72px;
      position: relative;
      overflow: hidden;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: minmax(0, 1.06fr) minmax(340px, 0.94fr);
      gap: 28px;
      align-items: center;
    }
    .hero-text {
      background: rgba(255,255,255,.92);
      border: 1px solid rgba(217, 231, 241, .9);
      border-radius: 40px;
      padding: 48px 44px;
      box-shadow: 0 24px 54px rgba(8, 77, 159, .08);
    }
    .hero-tag {
      display: inline-block;
      font-family: 'Montserrat', sans-serif;
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--primary-sub);
      border: 1px solid var(--primary);
      padding: 7px 16px;
      border-radius: 999px;
      margin-bottom: 28px;
      background: rgba(255,255,255,.75);
    }
    .hero h1 {
      font-size: clamp(1.96rem, 3.55vw, 3.2rem);
      font-weight: 900;
      line-height: 1.35;
      color: var(--primary-deep);
      letter-spacing: .02em;
      margin-bottom: 28px;
    }
    .hero h1 .accent { color: var(--primary-sub) }
    .hero p.lead {
      font-size: 1.03rem;
      color: var(--text-mid);
      line-height: 1.95;
      margin-bottom: 40px;
      max-width: 520px;
    }
    .hero-visual {
      position: relative;
      width: 100%;
      max-width: 560px;
      justify-self: end;
    }
    .hero-img-wrap {
      border-radius: 44px;
      overflow: hidden;
      background: linear-gradient(135deg, rgba(8,77,159,.12), rgba(91,195,236,.26));
      border: 1px solid rgba(255,255,255,.65);
      box-shadow: 0 32px 64px rgba(8, 77, 159, .14);
    }
    .hero-img-placeholder {
      height: 520px;
      background: linear-gradient(160deg, rgba(8,77,159,.92), rgba(44,166,224,.88));
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-img-placeholder img { width: 100%; height: 100%; object-fit: cover }

    .hero-stat-badge {
      position: absolute;
      bottom: 28px;
      left: 28px;
      background: var(--white);
      border: 1px solid rgba(91, 195, 236, .35);
      border-radius: 26px;
      padding: 20px 26px;
      box-shadow: 0 18px 40px rgba(0,0,0,.12);
    }
    .hero-stat-badge .num {
      font-family: 'Montserrat', sans-serif;
      font-size: 2.8rem;
      font-weight: 700;
      color: var(--primary-deep);
      line-height: 1;
      display: block;
    }
    .hero-stat-badge .desc { font-size: .75rem; color: var(--text-mid); margin-top: 4px; line-height: 1.5 }
    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      align-items: center;
    }
    .hero-cta-note {
      margin-top: 16px;
      font-size: .78rem;
      color: var(--text-light);
    }

    .hero-product-label {
      margin-top: 20px;
      margin-bottom: 32px;
      padding: 14px 18px;
      border: 1px solid var(--border);
      border-left: 3px solid var(--primary);
      border-radius: 6px;
      background: rgba(212, 223, 237, .22);
    }
    .hero-product-label .label-title {
      font-size: .95rem;
      font-weight: 700;
      color: var(--primary-deep);
      margin-bottom: 5px;
    }
    .hero-product-label .label-body {
      font-size: .75rem;
      color: var(--text-mid);
      line-height: 1.65;
    }

    /* ── Pain ── */
    .pain { background: var(--white) }
    .pain-intro { max-width: 600px }
    .pain-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
    .pain-card {
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-bottom: 3px solid transparent;
      border-radius: 28px;
      padding: 40px 36px;
      transition: background .2s, border-color .2s, transform .2s;
    }
    .pain-card:hover {
      background: var(--white);
      border-bottom-color: var(--primary);
      transform: translateY(-3px);
    }
    .pain-num {
      font-family: 'Montserrat', sans-serif;
      font-size: .72rem;
      font-weight: 600;
      color: var(--primary-deep);
      letter-spacing: .12em;
      margin-bottom: 20px;
      display: block;
    }
    .pain-card h3 { font-size: 1.05rem; font-weight: 700; color: var(--primary-deep); margin-bottom: 14px; line-height: 1.5 }
    .pain-card p { font-size: .88rem; color: var(--text-mid); line-height: 1.9 }
    .pain-data-tag {
      display: inline-block;
      font-family: 'Montserrat', sans-serif;
      font-size: .78rem;
      font-weight: 700;
      color: var(--primary-sub);
      margin-bottom: 10px;
    }

    /* ── About ── */
    .about { background: var(--surface-alt) }
    .about-inner { display: grid; grid-template-columns: 1fr 400px; gap: 72px; align-items: center }
    .about-text h3 { font-size: 1.5rem; font-weight: 700; color: var(--primary-deep); margin-bottom: 24px; line-height: 1.5 }
    .about-text p { font-size: .95rem; color: var(--text-mid); line-height: 2; margin-bottom: 20px }
    .about-features { display: flex; flex-direction: column; gap: 12px; margin-top: 28px }
    .about-feature {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 14px 16px;
      background: var(--white);
      border-left: 3px solid var(--primary);
      border-radius: 0 18px 18px 0;
    }
    .about-feature-icon { width: 20px; height: 20px; flex-shrink: 0; margin-top: 1px }
    .about-feature-text { font-size: .88rem; color: var(--text-mid); line-height: 1.6 }
    .about-feature-text strong { color: var(--primary-deep); display: block; margin-bottom: 2px }
    .about-img-wrap { border-radius: 2px; overflow: hidden }

    /* ── Use Cases ── */
    .usecases { background: var(--white) }
    .usecases-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px }
    .usecase-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-bottom: 3px solid var(--border);
      border-radius: 28px;
      padding: 36px 32px;
      transition: border-color .2s, transform .2s, box-shadow .2s;
    }
    .usecase-card:hover {
      border-bottom-color: var(--primary);
      transform: translateY(-3px);
      box-shadow: 0 18px 36px rgba(8, 77, 159, .07);
    }
    .usecase-num {
      font-family: 'Montserrat', sans-serif;
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--primary-deep);
      line-height: 1.5;
      margin-bottom: 16px;
    }
    .usecase-card h3 { font-size: 1.05rem; font-weight: 700; color: var(--primary-deep); margin-bottom: 12px; line-height: 1.55 }
    .usecase-card p { font-size: .88rem; color: var(--text-mid); line-height: 1.9 }
    .usecase-banner {
      margin-top: 44px;
      background: linear-gradient(135deg, var(--primary-deep), var(--primary-mid));
      padding: 40px 48px;
      text-align: center;
      border-radius: 34px;
    }
    .usecase-banner-label {
      font-family: 'Montserrat', sans-serif;
      font-size: .68rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(255,255,255,.55);
      margin-bottom: 12px;
    }
    .usecase-banner-text { font-size: 1.3rem; font-weight: 700; color: var(--white); line-height: 1.65; margin-bottom: 10px }
    .usecase-banner-text strong { color: var(--primary) }
    .usecase-banner-sub { font-size: .88rem; color: rgba(255,255,255,.82); line-height: 1.8 }

    /* ── Compare ── */
    .compare { background: var(--white) }
    .compare-header { max-width: 600px; margin-bottom: 48px }
    .compare-table-wrap { overflow-x: auto }
    .compare-table { width: 100%; border-collapse: collapse; font-size: .9rem }
    .compare-table th { padding: 16px 20px; text-align: center; font-weight: 700; font-size: .8rem; letter-spacing: .04em }
    .compare-table th:first-child { text-align: left }
    .compare-table thead tr { background: var(--primary-deep); color: var(--white) }
    .compare-table thead th.col-creins { background: var(--primary-sub) }
    .compare-table tbody td {
      padding: 16px 20px;
      text-align: center;
      border-bottom: 1px solid var(--border);
      color: var(--text-mid);
      vertical-align: middle;
    }
    .compare-table tbody td:first-child { text-align: left; font-weight: 700; color: var(--primary-deep); font-size: .87rem }
    .compare-table tbody tr:hover td { background: var(--surface) }
    .compare-table .col-creins { background: rgba(91,195,236,.12); font-weight: 700; color: var(--primary-deep) }
    .val-good { color: var(--green); font-weight: 700 }
    .val-bad  { color: var(--indicator-bad); font-weight: 500 }
    .val-mid  { color: var(--text-mid); font-weight: 500 }
    .val-good::before { content: '○ '; font-size: .85em }
    .val-bad::before  { content: '△ '; font-size: .85em }
    .compare-note { font-size: .75rem; color: var(--text-light); margin-top: 14px; text-align: right }

    /* ── Science ── */
    .science { background: var(--white) }

    /* Science cards */
    .science-cards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
      margin-bottom: 56px;
    }
    .science-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 28px;
      overflow: hidden;
      transition: border-color .2s, transform .2s, box-shadow .2s;
    }
    .science-card:hover {
      border-color: var(--primary);
      transform: translateY(-3px);
      box-shadow: 0 18px 36px rgba(8, 77, 159, .07);
    }
    .science-card-header {
      background: linear-gradient(135deg, var(--primary-deep), var(--primary-mid));
      padding: 18px 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .science-card-num {
      font-family: 'Montserrat', sans-serif;
      font-size: .65rem;
      font-weight: 600;
      letter-spacing: .12em;
      color: var(--primary);
    }
    .science-card-header h3 { font-size: .85rem; font-weight: 700; color: var(--white) }
    .science-card-body { padding: 24px 22px 26px }
    .science-card-body p { font-size: .83rem; color: var(--text-mid); line-height: 1.8 }
    .science-card-value {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--primary-sub);
      margin-bottom: 6px;
    }

    .science-inner { display: grid; grid-template-columns: 1fr 360px; gap: 64px; align-items: start }
    .science-text p { font-size: .93rem; line-height: 2; color: var(--text-mid); margin-bottom: 20px }
    .science-note { font-size: .75rem; color: var(--text-light); margin-top: 24px; line-height: 1.7; border-top: 1px solid var(--border); padding-top: 16px }

    .ph-chart {
      background: var(--white);
      border: 1px solid var(--border);
      padding: 32px 28px;
      border-radius: 32px;
      box-shadow: 0 14px 32px rgba(8, 77, 159, .05);
    }
    .ph-chart-title { font-size: .78rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; font-family: 'Montserrat', sans-serif; color: var(--text-light); margin-bottom: 28px }
    .ph-row { display: grid; grid-template-columns: 52px 1fr 52px; align-items: center; gap: 12px; margin-bottom: 16px }
    .ph-row-label { font-family: 'Montserrat', sans-serif; font-size: .75rem; color: var(--text-mid); text-align: right }
    .ph-bar-bg { height: 24px; background: var(--surface-blue); position: relative; overflow: hidden }
    .ph-bar-fill { height: 100%; transition: width .8s ease }
    .ph-bar-fill.c-high { background: var(--primary-sub) }
    .ph-bar-fill.c-mid  { background: #8cc9e6 }
    .ph-bar-fill.c-low  { background: var(--primary-mid) }
    .ph-row-val { font-family: 'Montserrat', sans-serif; font-size: .8rem; font-weight: 700; color: var(--text) }
    .ph-chart-source { font-size: .7rem; color: var(--text-light); margin-top: 20px; line-height: 1.6 }

    /* ── Regulation ── */
    .regulation { background: var(--surface-alt) }
    .regulation-inner { background: var(--white); border: 1px solid var(--border); border-radius: 34px; overflow: hidden }
    .regulation-header { background: linear-gradient(135deg, var(--primary-deep), var(--primary-mid)); padding: 24px 40px; display: flex; align-items: center; gap: 20px }
    .regulation-label {
      font-family: 'Montserrat', sans-serif;
      font-size: .65rem;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: rgba(255,255,255,.5);
      border: 1px solid rgba(255,255,255,.2);
      padding: 3px 10px;
      white-space: nowrap;
    }
    .regulation-header h3 { font-size: .95rem; font-weight: 700; color: var(--white) }
    .regulation-body { padding: 40px }
    .regulation-detail-table { width: 100%; border-collapse: collapse; font-size: .87rem; margin-bottom: 36px }
