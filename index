  <script>
    /* Smooth scroll */
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        e.preventDefault();
        const t = document.querySelector(a.getAttribute('href'));
        if (t) t.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    /* Accordion */
    document.querySelectorAll('.faq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        const panel = btn.nextElementSibling;
        panel.classList.toggle('open', !expanded);
      });
    });

    const floatingCta = document.getElementById('floatingCta');
    const orderSection = document.getElementById('order');
    const heroSection = document.getElementById('top');

    if (floatingCta && orderSection && 'IntersectionObserver' in window) {
      const floatingState = {
        heroVisible: false,
        orderVisible: false
      };

      const syncFloatingCta = () => {
        const shouldHide = floatingState.orderVisible || (window.innerWidth > 768 && floatingState.heroVisible);
        floatingCta.classList.toggle('is-hidden', shouldHide);
      };

      const toggleFloatingCta = entries => {
        entries.forEach(entry => {
          if (entry.target === orderSection) {
            floatingState.orderVisible = entry.isIntersecting;
          }

          if (entry.target === heroSection) {
            floatingState.heroVisible = entry.isIntersecting;
          }
        });

        syncFloatingCta();
      };

      const observer = new IntersectionObserver(toggleFloatingCta, {
        threshold: 0.2
      });

      if (heroSection) observer.observe(heroSection);
      observer.observe(orderSection);
      window.addEventListener('resize', syncFloatingCta);
    }
  </script>

